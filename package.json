{
  "name": "oweable",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "browserslist": [
    "defaults",
    "not IE 11",
    "not op_mini all",
    "Chrome >= 90",
    "Firefox >= 88",
    "Safari >= 14",
    "Edge >= 90"
  ],
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "vite build",
    "build:analyze": "ANALYZE=true vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit && eslint src",
    "security:edge-auth-gate": "node scripts/security/check-edge-function-auth-gate.mjs",
    "security:edge-log-hygiene": "node scripts/security/check-edge-log-hygiene.mjs",
    "security:edge-error-leakage": "node scripts/security/check-edge-error-leakage.mjs",
    "security:edge-baseline": "node scripts/security/check-edge-baseline.mjs",
    "security:edge-cors": "node scripts/security/check-edge-cors-hardening.mjs",
    "security:migrations-rls": "node scripts/security/check-supabase-migration-rls.mjs",
    "security:readiness": "node scripts/security/check-security-readiness.mjs",
    "secrets:scan": "gitleaks detect --source . --config .gitleaks.toml --redact --verbose",
    "test": "vitest run",
    "test:watch": "vitest",
    "generate:hero-loop": "node scripts/generate-hero-loop.mjs",
    "supabase": "supabase",
    "db:push": "supabase db push",
    "db:pull": "supabase db pull",
    "db:reset": "supabase db reset",
    "db:diff": "supabase db diff",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop",
    "supabase:status": "supabase status",
    "generate:icons": "tsx scripts/generate-icons.ts",
    "functions:deploy": "supabase functions deploy",
    "functions:deploy:admin-actions": "supabase functions deploy admin-actions"
  },
  "dependencies": {
    "@fontsource/geist-mono": "^5.2.7",
    "@fontsource/geist-sans": "^5.2.5",
    "@geist-ui/icons": "^1.0.2",
    "@headlessui/react": "^2.2.9",
    "@sentry/react": "^10.49.0",
    "@supabase/supabase-js": "^2.103.3",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.1.14",
    "@tanstack/react-query": "^5.99.0",
    "@tanstack/react-query-devtools": "^5.99.0",
    "@types/qrcode": "^1.5.6",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "@vitejs/plugin-react": "^5.0.4",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "pdfjs-dist": "^5.6.205",
    "qrcode": "^1.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-easy-crop": "^5.5.7",
    "react-is": "^19.0.0",
    "react-markdown": "^10.1.0",
    "react-plaid-link": "^4.1.1",
    "react-router-dom": "^7.13.2",
    "recharts": "^3.8.1",
    "rehype-sanitize": "^6.0.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7",
    "tesseract.js": "^7.0.0",
    "web-vitals": "^4.2.4",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@sentry/vite-plugin": "^4.9.1",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.4.0",
    "rollup-plugin-visualizer": "^7.0.1",
    "sharp": "^0.34.5",
    "supabase": "^2.92.1",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^8.0.8",
    "vite-plugin-checker": "^0.13.0",
    "vite-plugin-pwa": "^1.2.0",
    "vite-plugin-remove-console": "^2.2.0",
    "vitest": "^3.2.4",
    "workbox-window": "^7.4.0"
  }
}
