#!/bin/sh
# Pre-commit hook: Secret detection
# Blocks commits containing potential secrets or credentials

echo "🔒 Running secret detection..."

# Check for common secret patterns in staged changes
SECRETS_FOUND=0

# Pattern 1: Live API keys (Stripe, OpenAI, Anthropic, etc.)
if git diff --cached | grep -iE '(sk_live_[a-zA-Z0-9]{20,}|sk_test_[a-zA-Z0-9]{20,})'; then
  echo "❌ POTENTIAL LIVE API KEY DETECTED"
  SECRETS_FOUND=1
fi

# Pattern 2: GitHub tokens
if git diff --cached | grep -iE 'ghp_[a-zA-Z0-9]{36}'; then
  echo "❌ GITHUB TOKEN DETECTED"
  SECRETS_FOUND=1
fi

# Pattern 3: Slack tokens
if git diff --cached | grep -iE 'xox[baprs]-[a-zA-Z0-9-]+'; then
  echo "❌ SLACK TOKEN DETECTED"
  SECRETS_FOUND=1
fi

# Pattern 4: Private keys
if git diff --cached | grep -E '-----BEGIN (RSA |EC |DSA )?PRIVATE KEY-----'; then
  echo "❌ PRIVATE KEY DETECTED"
  SECRETS_FOUND=1
fi

# Pattern 5: Password assignments with long values
if git diff --cached | grep -iE 'password\s*=\s*["\x27][^"\x27]{8,}'; then
  echo "❌ POTENTIAL PASSWORD DETECTED"
  SECRETS_FOUND=1
fi

# Pattern 6: AWS credentials
if git diff --cached | grep -iE 'AKIA[0-9A-Z]{16}'; then
  echo "❌ AWS ACCESS KEY DETECTED"
  SECRETS_FOUND=1
fi

# Pattern 7: Generic secret/token patterns
if git diff --cached | grep -iE '(secret|token|api_key)\s*=\s*["\x27][a-zA-Z0-9+/=]{20,}'; then
  echo "⚠️  POTENTIAL SECRET/TOKEN PATTERN DETECTED"
  echo "   If this is a test value, add it to .gitleaks.toml allowlist"
  SECRETS_FOUND=1
fi

if [ $SECRETS_FOUND -eq 1 ]; then
  echo ""
  echo "❌ COMMIT BLOCKED: Potential secrets detected"
  echo ""
  echo "Please:"
  echo "  1. Remove secrets from your changes"
  echo "  2. Use environment variables instead of hardcoded values"
  echo "  3. For test values, use .env.test with dummy credentials"
  echo "  4. If false positive, add pattern to .gitleaks.toml allowlist"
  echo ""
  exit 1
fi

echo "✅ No secrets detected"
exit 0
