# Oweable — Environment Variables
# Copy to `.env.local` and fill in values. Never commit `.env*` (gitignored except this file).
#
# Vite only exposes variables prefixed with VITE_ to the browser.

# Optional: Sentry browser SDK (https://sentry.io). Create a React project and paste the DSN.
# Leave unset to disable client-side error reporting.
# VITE_SENTRY_DSN=https://xxxx@xxxx.ingest.sentry.io/xxxx
# Optional: release name for source maps / regressions (e.g. git SHA from CI).
# VITE_SENTRY_RELEASE=oweable@1.0.0+abc1234
# Optional alias used in release resolution if VITE_SENTRY_RELEASE is unset:
# VITE_APP_VERSION=1.0.0
# Optional: force Sentry environment (overrides Vercel’s VERCEL_ENV). Usually omit.
# VITE_SENTRY_ENVIRONMENT=staging
# Optional: send every INP sample to Sentry (default: only needs-improvement + poor ratings).
# VITE_WEB_VITALS_VERBOSE=true
#
# ── Vercel + Sentry ───────────────────────────────────────────────────────────
# Vercel injects VERCEL_ENV (production | preview | development) and VERCEL_GIT_COMMIT_SHA.
# Events use that environment; release defaults to oweable@<VERCEL_GIT_COMMIT_SHA> when no
# VITE_SENTRY_RELEASE / SENTRY_RELEASE / VITE_APP_VERSION is set.
#
# In Vercel → Project → Settings → Environment Variables:
#   Production + Preview: VITE_SENTRY_DSN
#   Optional (all): VITE_SENTRY_RELEASE or VITE_APP_VERSION if you don’t want SHA-based releases
#   Production build only (mark Sensitive): SENTRY_AUTH_TOKEN, SENTRY_ORG, SENTRY_PROJECT
#   Do not prefix Sentry secrets with VITE_ (they would leak to the browser).
#
# Source maps upload (production build only — CI / Vercel, never VITE_*):
# SENTRY_ORG=your-org-slug
# SENTRY_PROJECT=your-project-slug
# SENTRY_AUTH_TOKEN=sntrys_...
# Optional CI-only override (same priority as VITE_SENTRY_RELEASE in release resolution):
# SENTRY_RELEASE=oweable@abc1234

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Must match the signed-in Google email of the sole /admin operator (same value as ADMIN_ALLOWED_EMAIL secret).
VITE_ADMIN_EMAIL=you@example.com

# Bank linking (Plaid) in Settings → Integrations. Omit or set to false until launch; use true when ready.
# VITE_PLAID_LINK_UI_ENABLED=false

# Optional: server-side tooling (never use VITE_ prefix).
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
# MCP hardening: require explicit per-user allowlist when running `server/server.ts`.
# MCP_ALLOWED_USER_IDS=uuid-1,uuid-2
# MCP_ENFORCE_ALLOWLIST=true

# ── Stripe Billing (server-only except publishable key) ─────────────────────
# Client-safe key for Stripe.js (publishable only; never use sk_* here).
# Use pk_test_* in local dev, pk_live_* in production.
# NOTE: All billing operations go through Supabase Edge Functions (no direct Stripe.js calls
# in the current frontend). Set this if you add client-side Stripe.js usage in future.
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...
# Optional display values for marketing pages (must match Stripe Prices).
VITE_PRICING_MONTHLY_DISPLAY=10.99
# Annual Full Suite — 30% off vs 12× monthly ($10.99×12×0.70 = $92.32, effective $7.69/mo)
VITE_PRICING_YEARLY_DISPLAY=92.32
# Set these in Supabase Edge Function secrets:
# Sole operator for admin-actions Edge Function (lowercase email).
ADMIN_ALLOWED_EMAIL=you@example.com
# Server-only Stripe secret key. Use sk_test_* for test environments and sk_live_* for production.
STRIPE_SECRET_KEY=sk_test_...
# Must be the Signing secret from the webhook endpoint that points at this project (whsec_...).
# Copy from Stripe Dashboard → Developers → Webhooks → [this endpoint] → Signing secret.
# Test-mode secret only matches test events; live secret only matches live events.
STRIPE_WEBHOOK_SECRET=whsec_...
# Production Full Suite is $10.99/mo only — set STRIPE_PRICE_PRO_MONTHLY to that Price ID.
# Other amounts in the Stripe Dashboard (e.g. alternate monthly/yearly/one-time) are sandbox-only; do not use them in secrets.
STRIPE_PRICE_PRO_MONTHLY=price_...
# Yearly (10% off): set the active Full Suite yearly price id for your environment.
# Use a test-mode price_... for local/test and a live-mode price_... in production.
STRIPE_PRICE_PRO_YEARLY=price_...
# Optional: link from Admin → Billing to your Stripe Dashboard (test or live).
# VITE_STRIPE_DASHBOARD_URL=https://dashboard.stripe.com/test

# ── Plaid (server-only — used by Supabase Edge Functions, NOT by Vite) ──────
# Set these in Supabase Dashboard → Project Settings → Edge Functions → Secrets,
# or CLI: supabase secrets set PLAID_CLIENT_ID=... --project-ref YOUR_REF
# (repeat for each name below). Do not put PLAID_* in Vite; the app calls Edge Functions only.

PLAID_CLIENT_ID=
PLAID_SECRET=
# sandbox | development | production
PLAID_ENV=sandbox

# Optional
PLAID_CLIENT_NAME=Oweable
# OAuth institutions (Chase/Wells/etc): register this exact URI in Plaid Dashboard and set as Supabase secret.
# PLAID_REDIRECT_URI=https://oweable.com/plaid/callback
# Comma-separated browser origins allowed to call Plaid Edge Functions (in addition to oweable.com + *.vercel.app)
# PLAID_ALLOWED_ORIGINS=https://oweable.com,https://www.oweable.com,http://localhost:5173
# Supabase Edge secret: extra exact Origins for CORS (e.g. preview URLs not matching oweable/vercel heuristics)
# EDGE_CORS_EXTRA_ORIGINS=https://your-branch.vercel.app

# Cron: POST /functions/v1/plaid-sync with Authorization: Bearer <this value>
# PLAID_CRON_SECRET=
# PLAID_SYNC_BATCH_SIZE=40
# PLAID_SYNC_STALE_HOURS=6

# Local webhook testing only — never enable in production
# PLAID_SKIP_WEBHOOK_VERIFY=false

# ── Web Push (browser notifications) ───────────────────────────────────────
# Generate VAPID keys once (e.g. `npx web-push generate-vapid-keys`). Public key
# goes in Vite and in Supabase (same value). Private key is server-only.
# VITE_VAPID_PUBLIC_KEY=
# Supabase Edge Function secrets (same project as other secrets):
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# WEB_PUSH_SUBJECT=mailto:support@oweable.com
# Optional cron-style secret reserved for future scheduled sends:
# WEB_PUSH_CRON_SECRET=
# Secure `send-reengagement-push` scheduled endpoint:
# REENGAGEMENT_CRON_SECRET=
# Optional admin-alert sender override (must be a verified sender in Resend):
# ADMIN_ALERTS_FROM_EMAIL=alerts@oweable.com

# ── Plaid Dashboard MCP (Cursor — production tooling) ─────────────────────
# https://plaid.com/docs/resources/mcp/ — requires production access + prod keys.
# .cursor/mcp.json runs scripts/plaid-dashboard-mcp.sh (mcp-remote → api.dashboard.plaid.com).
# Uses PLAID_CLIENT_ID + PLAID_SECRET from below if they are PRODUCTION keys; otherwise set:
# PLAID_DASHBOARD_CLIENT_ID=
# PLAID_DASHBOARD_SECRET=
# Token is refreshed each time the MCP process starts (~15 min lifetime).

# ── Google Cross-Account Protection (RISC) — Edge Function secrets only ───────
# Enable RISC API + create a service account with role "RISC Configuration Admin" in the same
# GCP project as your Google Sign-In OAuth clients. Download JSON; store the whole JSON
# string (one line) as RISC_SERVICE_ACCOUNT_JSON. Accept the RISC Terms in API Console.
# Comma-separated OAuth 2.0 Web client IDs whose JWT `aud` you accept (e.g. Supabase Auth Google
# client + Gmail client if different): must match tokens Google sends.
# RISC_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# RISC_GOOGLE_OAUTH_CLIENT_IDS=123....apps.googleusercontent.com,456....apps.googleusercontent.com
# Optional: full HTTPS URL if not `${SUPABASE_URL}/functions/v1/risc-google-receiver`
# RISC_RECEIVER_URL=https://YOUR_REF.supabase.co/functions/v1/risc-google-receiver
# Strong random secret; required header x-risc-register-secret on risc-google-register calls.
# RISC_REGISTER_SECRET=

# ── Resend (email delivery) — Edge Function secrets only ──────────────────────
# Get API key from https://resend.com/api-keys
# RESEND_API_KEY=re_...
# Email addresses for different purposes
# VITE_CONTACT_EMAIL=hello@oweable.com
# VITE_SUPPORT_EMAIL=support@oweable.com
# VITE_NOREPLY_EMAIL=noreply@oweable.com
# RESEND_FROM_EMAIL=noreply@oweable.com
# ADMIN_ALERTS_FROM_EMAIL=alerts@oweable.com
# ADMIN_ALERTS_TO_EMAIL=support@oweable.com
# SUPPORT_EMAIL=support@oweable.com

# ── Cloudflare Turnstile — public form abuse protection ───────────────────────
# Turnstile secret for Edge Functions that verify public form submissions.
# CF_TURNSTILE_SECRET_KEY=your_turnstile_secret
# Browser site key for forms that render the Turnstile widget.
# VITE_TURNSTILE_SITE_KEY=your_turnstile_site_key
