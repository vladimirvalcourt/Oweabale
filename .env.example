# Oweable — Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit .env — it is gitignored.

VITE_SUPABASE_URL=your_supabase_project_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Server-side (used by `server/server.ts` MCP server). Keep these secret.
# Do NOT expose them to the browser (never prefix with VITE_).
SUPABASE_URL=your_supabase_project_url_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Plaid — configure in Supabase Dashboard → Edge Functions → Secrets (not in Vite):
# PLAID_CLIENT_ID, PLAID_SECRET, PLAID_ENV=sandbox (or development | production)
# Optional: PLAID_CLIENT_NAME=Oweable
# After setting secrets: deploy functions `plaid-link-token` and `plaid-exchange`.
